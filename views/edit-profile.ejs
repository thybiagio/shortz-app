<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Perfil | Shortz-App</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>

<body>

    <!-- Navbar (modelo home.ejs) -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm">
        <div class="container-fluid px-lg-5">
            <a class="navbar-brand" href="/feed">
                <i class="bi bi-play-fill"></i> SHORTZ
            </a>

            <!-- Campo de Busca -->
            <form class="d-none d-md-flex mx-auto" style="width: 40%;">
                <div class="input-group">
                    <input type="text" class="form-control bg-light border-0"
                        placeholder="Pesquisar vídeos ou usuários..." style="border-radius: 20px 0 0 20px;">
                    <button class="btn btn-light border-0" type="button" style="border-radius: 0 20px 20px 0;">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </form>

            <div class="d-flex align-items-center">
                <a href="/upload" class="btn btn-outline-dark border-0 me-3 d-none d-sm-block">
                    <i class="bi bi-plus-square me-1"></i> Upload
                </a>
                <div class="dropdown">
                    <a href="#" class="d-block link-dark text-decoration-none dropdown-toggle" id="dropdownUser"
                        data-bs-toggle="dropdown" aria-expanded="false">
                        <img src="<%= user.profilePicture ? '/uploads/profiles/' + user.profilePicture : '/images/default-profile.png' %>"
                            alt="mdo" width="32" height="32" class="bg-secondary">
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end text-small shadow border-0 mt-2" aria-labelledby="dropdownUser">
                        <li><a class="dropdown-item py-2" href="/profile/edit"><i class="bi bi-person me-2"></i> Ver Perfil</a></li>
                        <li><a class="dropdown-item py-2" href="/my-videos"><i class="bi bi-camera-video me-2"></i> Meus Vídeos</a></li>
                        <li><a class="dropdown-item py-2" href="/settings"><i class="bi bi-gear me-2"></i> Configurações</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item py-2 text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i> Sair</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <main class="container py-5 mb-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">

                <!-- Alertas -->
                <% if (messages.error && messages.error.length> 0) { %>
                    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <%= messages.error %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>

                <% if (messages.success && messages.success.length> 0) { %>
                    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        <%= messages.success %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>

                <!-- Card (modelo login.ejs / register.ejs) -->
                <div class="card auth-card">
                    <div class="auth-header">
                        <h2 class="fw-bold mb-0">Editar Perfil</h2>
                        <p class="text-white-50 small mt-2">Atualize suas informações pessoais</p>
                    </div>
                    <div class="card-body p-4 p-md-5">

                        <form action="/profile/edit" method="POST" enctype="multipart/form-data">

                            <!-- Foto de Perfil -->
                            <div class="text-center mb-4">
                                <div class="position-relative d-inline-block">
                                    <img src="<%= user.profilePicture ? '/uploads/profiles/' + user.profilePicture : '/images/default-profile.png' %>"
                                        alt="Avatar" class="rounded-circle border shadow-sm mb-2" id="imgPreview"
                                        width="110" height="110" style="object-fit: cover;">
                                    <label for="profilePicture"
                                        class="btn btn-sm btn-dark position-absolute bottom-0 end-0 rounded-circle d-flex align-items-center justify-content-center shadow"
                                        style="width: 34px; height: 34px; padding: 0;">
                                        <i class="bi bi-camera-fill" style="font-size: 0.85rem;"></i>
                                    </label>
                                    <input type="file" class="d-none" id="profilePicture" name="profilePicture"
                                        accept="image/*" onchange="previewImage(this)">
                                </div>
                                <p class="small text-muted mt-2 mb-0">Clique no ícone para alterar sua foto</p>
                            </div>

                            <!-- Nome de Usuário (desabilitado) -->
                            <div class="mb-3">
                                <label for="username" class="form-label fw-semibold">Nome de Usuário</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0">
                                        <i class="bi bi-at"></i>
                                    </span>
                                    <input type="text" class="form-control bg-light border-start-0"
                                        id="username" value="<%= user.username %>" disabled>
                                </div>
                                <div class="form-text text-muted">O nome de usuário não pode ser alterado.</div>
                            </div>

                            <!-- Nome Completo -->
                            <div class="mb-3">
                                <label for="fullName" class="form-label fw-semibold">Nome Completo</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0">
                                        <i class="bi bi-person"></i>
                                    </span>
                                    <input type="text" class="form-control bg-light border-start-0"
                                        id="fullName" name="fullName"
                                        value="<%= user.fullName || '' %>" placeholder="Seu nome completo">
                                </div>
                            </div>

                            <!-- Biografia -->
                            <div class="mb-4">
                                <label for="bio" class="form-label fw-semibold">Biografia</label>
                                <div class="input-group align-items-start">
                                    <span class="input-group-text bg-light border-end-0" style="padding-top: 0.55rem;">
                                        <i class="bi bi-pencil"></i>
                                    </span>
                                    <textarea class="form-control bg-light border-start-0"
                                        id="bio" name="bio" rows="3" maxlength="255"
                                        placeholder="Conte um pouco sobre você..."><%= user.bio || '' %></textarea>
                                </div>
                                <div class="form-text text-end small" id="charCount">0/255</div>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 mb-3 shadow-sm fw-bold">
                                Salvar Alterações
                            </button>

                            <div class="text-center mt-2">
                                <a href="/feed" class="text-muted small text-decoration-none">
                                    <i class="bi bi-arrow-left me-1"></i> Cancelar e voltar ao Feed
                                </a>
                            </div>

                        </form>
                    </div>
                </div>

            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-dark text-white py-4">
        <div class="container text-center">
            <p class="mb-0 small">&copy; 2026 Shortz-App. Desenvolvido na disciplina ServerSide.</p>
        </div>
    </footer>

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Preview da imagem antes do upload
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('imgPreview').src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        // Contador de caracteres para a bio
        const bio = document.getElementById('bio');
        const charCount = document.getElementById('charCount');

        bio.addEventListener('input', () => {
            charCount.textContent = `${bio.value.length}/255`;
        });

        // Inicializar contador
        charCount.textContent = `${bio.value.length}/255`;
    </script>
</body>

</html>