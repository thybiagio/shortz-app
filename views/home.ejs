<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Feed | Shortz-App</title>
  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
  <style>
    :root {
      --primary-color: #ff0050;
      --secondary-color: #00f2ea;
    }
    body {
      background-color: #f8f9fa;
    }
    .navbar-brand {
      font-weight: 800;
      color: var(--primary-color) !important;
    }
    .sidebar {
      background: white;
      border-right: 1px solid #eee;
      height: calc(100vh - 56px);
      position: sticky;
      top: 56px;
    }
    .nav-link {
      color: #333;
      font-weight: 500;
      padding: 12px 20px;
      border-radius: 10px;
      margin-bottom: 5px;
    }
    .nav-link:hover, .nav-link.active {
      background-color: rgba(255, 0, 80, 0.05);
      color: var(--primary-color);
    }
    .video-card {
      border: none;
      border-radius: 15px;
      overflow: hidden;
      transition: transform 0.3s;
      background: white;
      box-shadow: 0 4px 15px rgba(0,0,0,0.1);
      margin-bottom: 20px;
    }
    .thumbnail-placeholder {
      width: 100%;
      aspect-ratio: 9/16;
      background-color: #000;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #666;
      position: relative;
    }
    .play-icon {
      font-size: 3rem;
      color: rgba(255,255,255,0.8);
    }
    .badge-views {
      position: absolute;
      bottom: 10px;
      left: 10px;
      background: rgba(0,0,0,0.6);
      padding: 2px 8px;
      border-radius: 5px;
      font-size: 0.8rem;
      color: white;
    }
    .user-avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      object-fit: cover;
      background-color: #ddd;
    }
  </style>
</head>
<body>

  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm">
    <div class="container-fluid px-lg-5">
      <a class="navbar-brand" href="/feed">
        <i class="bi bi-play-fill"></i> SHORTZ
      </a>
      
      <!-- Campo de Busca -->
      <form class="d-none d-md-flex mx-auto" style="width: 40%;">
        <div class="input-group">
          <input type="text" class="form-control bg-light border-0" placeholder="Pesquisar vídeos ou usuários..." style="border-radius: 20px 0 0 20px;">
          <button class="btn btn-light border-0" type="button" style="border-radius: 0 20px 20px 0;">
            <i class="bi bi-search"></i>
          </button>
        </div>
      </form>

      <div class="d-flex align-items-center">
        <a href="/upload" class="btn btn-outline-dark border-0 me-3 d-none d-sm-block">
          <i class="bi bi-plus-square me-1"></i> Upload
        </a>
        <div class="dropdown">
          <a href="#" class="d-block link-dark text-decoration-none dropdown-toggle" id="dropdownUser" data-bs-toggle="dropdown" aria-expanded="false">
            <img src="/images/default-profile.png" alt="mdo" width="32" height="32" class="rounded-circle bg-secondary">
          </a>
          <ul class="dropdown-menu dropdown-menu-end text-small shadow border-0 mt-2" aria-labelledby="dropdownUser">
            <li><a class="dropdown-item py-2" href="/profile"><i class="bi bi-person me-2"></i> Ver Perfil</a></li>
            <li><a class="dropdown-item py-2" href="/my-videos"><i class="bi bi-camera-video me-2"></i> Meus Vídeos</a></li>
            <li><a class="dropdown-item py-2" href="/settings"><i class="bi bi-gear me-2"></i> Configurações</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item py-2 text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i> Sair</a></li>
          </ul>
        </div>
      </div>
    </div>
  </nav>

  <div class="container-fluid px-lg-5">
    <div class="row">
      <!-- Sidebar (Desktop) -->
      <aside class="col-md-3 col-lg-2 d-none d-md-block sidebar py-4">
        <nav class="nav flex-column">
          <a class="nav-link active" href="/feed"><i class="bi bi-house-door-fill me-2"></i> Para Você</a>
          <a class="nav-link" href="/following"><i class="bi bi-people me-2"></i> Seguindo</a>
          <a class="nav-link" href="/explore"><i class="bi bi-compass me-2"></i> Explorar</a>
          <hr>
          <p class="small text-muted px-3 mb-2">Minha Atividade</p>
          <a class="nav-link py-2" href="/playlists"><i class="bi bi-collection-play me-2"></i> Playlists</a>
          <a class="nav-link py-2" href="/liked"><i class="bi bi-heart me-2"></i> Curtidas</a>
        </nav>
      </aside>

      <!-- Main Content -->
      <main class="col-12 col-md-9 col-lg-10 py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h4 class="fw-bold mb-0">Feed Global</h4>
          <div class="btn-group shadow-sm">
            <button class="btn btn-white btn-sm active border">Recentes</button>
            <button class="btn btn-white btn-sm border">Populares</button>
          </div>
        </div>

        <div class="row g-4">
          <!-- Video Card 1 -->
          <div class="col-6 col-md-4 col-lg-3">
            <div class="video-card">
              <div class="thumbnail-placeholder">
                <i class="bi bi-play-circle play-icon"></i>
                <span class="badge-views"><i class="bi bi-eye"></i> 1.2k</span>
              </div>
              <div class="p-3">
                <h6 class="text-truncate mb-1">Como fazer Café Gelado</h6>
                <div class="d-flex align-items-center">
                  <span class="text-muted small">@cafe_master</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Video Card 2 -->
          <div class="col-6 col-md-4 col-lg-3">
            <div class="video-card">
              <div class="thumbnail-placeholder">
                <i class="bi bi-play-circle play-icon"></i>
                <span class="badge-views"><i class="bi bi-eye"></i> 850</span>
              </div>
              <div class="p-3">
                <h6 class="text-truncate mb-1">Dica de Node.js #01</h6>
                <span class="text-muted small">@dev_junior</span>
              </div>
            </div>
          </div>

          <!-- Video Card 3 -->
          <div class="col-6 col-md-4 col-lg-3">
            <div class="video-card">
              <div class="thumbnail-placeholder">
                <i class="bi bi-play-circle play-icon"></i>
                <span class="badge-views"><i class="bi bi-eye"></i> 2.5k</span>
              </div>
              <div class="p-3">
                <h6 class="text-truncate mb-1">Setup Minimalista 2026</h6>
                <span class="text-muted small">@tech_lover</span>
              </div>
            </div>
          </div>

          <!-- Video Card 4 -->
          <div class="col-6 col-md-4 col-lg-3">
            <div class="video-card">
              <div class="thumbnail-placeholder">
                <i class="bi bi-play-circle play-icon"></i>
                <span class="badge-views"><i class="bi bi-eye"></i> 3.1k</span>
              </div>
              <div class="p-3">
                <h6 class="text-truncate mb-1">Viagem rápida: Japão</h6>
                <span class="text-muted small">@travel_vlog</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Botão Carregar Mais -->
        <div class="text-center mt-5">
          <button class="btn btn-outline-primary px-5 rounded-pill fw-bold">Carregar mais vídeos</button>
        </div>
      </main>
    </div>
  </div>

  <!-- Bootstrap 5 JS Bundle -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
