<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Perfil | Shortz-App</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>

<body>

    <!-- Navbar (modelo home.ejs) -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm">
        <div class="container-fluid px-lg-5">
            <a class="navbar-brand" href="/feed">
                <i class="bi bi-play-fill"></i> SHORTZ
            </a>

            <!-- Campo de Busca -->
            <form class="d-none d-md-flex mx-auto" style="width: 40%;">
                <div class="input-group">
                    <input type="text" class="form-control bg-light border-0"
                        placeholder="Pesquisar vídeos ou usuários..." style="border-radius: 20px 0 0 20px;">
                    <button class="btn btn-light border-0" type="button" style="border-radius: 0 20px 20px 0;">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </form>

            <div class="d-flex align-items-center">
                <a href="/upload" class="btn btn-outline-dark border-0 me-3 d-none d-sm-block">
                    <i class="bi bi-plus-square me-1"></i> Upload
                </a>
                <div class="dropdown">
                    <a href="#" class="d-block link-dark text-decoration-none dropdown-toggle" id="dropdownUser"
                        data-bs-toggle="dropdown" aria-expanded="false">
                        <img src="<%= avatarSrc(user.profilePicture) %>"
                            alt="mdo" width="32" height="32" class="bg-secondary">
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end text-small shadow border-0 mt-2" aria-labelledby="dropdownUser">
                        <li><a class="dropdown-item py-2" href="/profile/edit"><i class="bi bi-person me-2"></i> Ver Perfil</a></li>
                        <li><a class="dropdown-item py-2" href="/my-videos"><i class="bi bi-camera-video me-2"></i> Meus Vídeos</a></li>
                        <li><a class="dropdown-item py-2" href="/settings"><i class="bi bi-gear me-2"></i> Configurações</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item py-2 text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i> Sair</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="profile-card p-4">
                <h2 class="fw-bold mb-4 text-center">Editar Perfil</h2>
                <form action="/profile/edit" method="POST" enctype="multipart/form-data">
                    <div class="text-center mb-4">
                        <img src="<%= avatarSrc(user.profilePicture) %>" 
                            alt="Foto de Perfil" class="avatar-preview" id="profileImagePreview">
                        <div class="mt-3">
                            <label for="profilePicture" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-camera me-2"></i> Alterar Foto
                            </label>
                            <input type="file" id="profilePicture" name="profilePicture" accept="image/*" class="d-none">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="username" class="form-label">Nome de Usuário</label>
                        <input type="text" class="form-control" id="username" name="username" value="<%= user.username %>" disabled>
                    </div>

                    <div class="mb-3">
                        <label for="fullName" class="form-label">Nome Completo</label>
                        <input type="text" class="form-control" id="fullName" name="fullName" value="<%= user.fullName %>">
                    </div>

                    <div class="mb-3">
                        <label for="bio" class="form-label">Bio</label>
                        <textarea class="form-control" id="bio" name="bio" rows="3" maxlength="255"><%= user.bio %></textarea>
                        <div id="bioHelp" class="form-text text-end"><span id="charCount">
                                         <%= user.bio ? user.bio.length : 0 %></span>/255</div>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">Salvar Alterações</button>
                        <a href="/feed" class="btn btn-outline-secondary btn-lg">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
   
   // Script para preview da imagem de perfil
    document.getElementById("profilePicture").addEventListener("change", function (e) {
        if (e.target.files && e.target.files[0]) {
            var reader = new FileReader();
            reader.onload = function (event) {
                document.getElementById("profileImagePreview").src = event.target.result;
            };
            reader.readAsDataURL(e.target.files[0]);
        }
    });

    // Script para contador de caracteres da bio
    const bioTextarea = document.getElementById("bio");
    const charCountSpan = document.getElementById("charCount");

    bioTextarea.addEventListener("input", function () {
        charCountSpan.textContent = this.value.length;
    });
</script>

    <!-- Footer -->
    <footer class="bg-dark text-white py-4">
        <div class="container text-center">
            <p class="mb-0 small">&copy; 2026 Shortz-App. Desenvolvido na disciplina ServerSide.</p>
        </div>
    </footer>

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Preview da imagem antes do upload
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('imgPreview').src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        // Contador de caracteres para a bio
        const bio = document.getElementById('bio');
        const charCount = document.getElementById('charCount');

        bio.addEventListener('input', () => {
            charCount.textContent = `${bio.value.length}/255`;
        });

        // Inicializar contador
        charCount.textContent = `${bio.value.length}/255`;
    </script>
</body>

</html>
