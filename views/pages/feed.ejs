<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Feed | Shortz-App</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm">
        <div class="container-fluid px-lg-5">
            <a class="navbar-brand fw-bold" href="/feed">
                <i class="bi bi-play-fill text-danger"></i> SHORTZ
            </a>

            <!-- Campo de Busca -->
            <form class="d-none d-md-flex mx-auto" style="width: 40%;">
                <div class="input-group">
                    <input type="text" class="form-control bg-light border-0"
                        placeholder="Pesquisar vídeos ou usuários..." style="border-radius: 20px 0 0 20px;">
                    <button class="btn btn-light border-0" type="button" style="border-radius: 0 20px 20px 0;">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </form>

            <div class="d-flex align-items-center">
                <a href="/upload" class="btn btn-outline-dark border-0 me-3 d-none d-sm-block">
                    <i class="bi bi-plus-square me-1"></i> Upload
                </a>
                <div class="dropdown">
                    <a href="#" class="d-block link-dark text-decoration-none dropdown-toggle" id="dropdownUser"
                        data-bs-toggle="dropdown" aria-expanded="false">
                        <img src="<%= user.profilePicture ? '/uploads/profiles/' + user.profilePicture : '/images/default-profile.png' %>" 
                            alt="mdo" width="32" height="32" class="rounded-circle bg-secondary">
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end text-small shadow border-0 mt-2" aria-labelledby="dropdownUser">
                        <li><a class="dropdown-item py-2" href="/profile/edit"><i class="bi bi-person me-2"></i> Ver Perfil</a></li>
                        <li><a class="dropdown-item py-2" href="/my-videos"><i class="bi bi-camera-video me-2"></i> Meus Vídeos</a></li>
                        <li><a class="dropdown-item py-2" href="/settings"><i class="bi bi-gear me-2"></i> Configurações</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item py-2 text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i> Sair</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <!-- Conteúdo da Página -->
    <div class="container-fluid px-lg-5">
        <div class="row">
            <!-- Sidebar -->
            <%- include("../partials/sidebar") %>

            <!-- Main Content -->
            <main class="col-12 col-md-9 col-lg-10 py-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="fw-bold mb-0">Feed Global</h4>
                    <div class="btn-group shadow-sm">
                        <button class="btn btn-white btn-sm active border">Recentes</button>
                        <button class="btn btn-white btn-sm border">Populares</button>
                    </div>
                </div>

                <div class="row g-4">
                    <% if (videos && videos.length > 0) { %>
                        <% videos.forEach(video => { %>
                            <!-- Video Card -->
                            <div class="col-6 col-md-4 col-lg-3">
                                <div class="video-card h-100 shadow-sm border-0 rounded-3 overflow-hidden bg-white">
                                    <a href="/video/<%= video.id %>" class="text-decoration-none">
                                        <div class="thumbnail-placeholder position-relative" 
                                             style="background-image: url('/uploads/covers/<%= video.thumbnailPath %>'); background-size: cover; background-position: center; height: 180px;">
                                            <i class="bi bi-play-circle play-icon"></i>
                                            <span class="badge-views"><i class="bi bi-eye"></i> <%= video.views %></span>
                                        </div>
                                    </a>
                                    <div class="p-3">
                                        <h6 class="text-truncate mb-1">
                                            <a href="/video/<%= video.id %>" class="text-decoration-none text-dark fw-bold">
                                                <%= video.title %>
                                            </a>
                                        </h6>
                                        <div class="d-flex align-items-center mt-2">
                                            <img src="<%= video.User.profilePicture ? '/uploads/profiles/' + video.User.profilePicture : '/images/default-profile.png' %>" 
                                                alt="<%= video.User.username %>" class="rounded-circle me-2" width="24" height="24">
                                            <span class="text-muted small">@<%= video.User.username %></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="col-12">
                            <div class="alert alert-info text-center py-5" role="alert">
                                <i class="bi bi-info-circle fs-2 d-block mb-2"></i>
                                Nenhum vídeo disponível no momento. Seja o primeiro a enviar um!
                            </div>
                        </div>
                    <% } %>
                </div>

                <!-- Botão Carregar Mais -->
                <div class="text-center mt-5 mb-5">
                    <button class="btn btn-outline-primary px-5 rounded-pill fw-bold">Carregar mais vídeos</button>
                </div>
            </main>
        </div>
    </div>

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>